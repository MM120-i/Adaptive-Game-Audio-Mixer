{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake Configure",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S", ".",
        "-B", "build",
        "-G", "Visual Studio 18 2026",
        "-A", "x64"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Build (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build", "build",
        "--config", "Debug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": ["CMake Configure"],
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Build (Release)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build", "build",
        "--config", "Release"
      ],
      "group": "build",
      "dependsOn": ["CMake Configure"],
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Run",
      "type": "shell",
      "command": ".",
      "args": [
        "\\build\\AudioMixer_artefacts\\${config:AudioMixer.buildConfig}\\AudioMixer.exe"
      ],
      "dependsOn": ["Build (Debug)"],
      "problemMatcher": [],
      "presentation": {
        "clear": true,
        "panel": "dedicated"
      }
    },
    {
      "label": "Test",
      "type": "shell",
      "command": "ctest",
      "args": ["--output-on-failure"],
      "options": {
        "cwd": "${workspaceFolder}/build"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "if",
      "args": [
        "Test-Path", "build",
        "{", "Remove-Item", "-Recurse", "-Force", "build", "}"
      ],
      "problemMatcher": []
    }
  ]
}
